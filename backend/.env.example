# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://username:password@localhost:5432/ride_share_db"

# ─── Cloudinary ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="your_super_secret_jwt_key_min_32_chars_change_this"
JWT_REFRESH_SECRET="your_super_secret_refresh_key_min_32_chars_change_this"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Resend Email API (primary) ───────────────────────────────────────────────
RESEND_API_KEY="re_your_resend_api_key_here"
EMAIL_FROM="RideShare NIT KKR <noreply@nitkkr.ac.in>"

# ─── Nodemailer SMTP (fallback) ───────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_gmail@gmail.com"
SMTP_PASS="your_gmail_app_password"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV="development"

# ─── Domain Whitelist (comma-separated) ──────────────────────────────────────
ALLOWED_DOMAINS="nitkkr.ac.in"

# ─── Frontend URL (CORS) ──────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
OTP_RATE_LIMIT_MAX=5
